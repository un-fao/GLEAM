\deqn{
  N₂O =
  nitrogen\_excretion \times ratio\_N2ON\_to\_N2O \times
  \sum_{S} \left(
    manure\_management\_system\_fraction \times
    nitrogen\_fracgas \times
    n2o\_ef4
